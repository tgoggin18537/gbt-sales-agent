{
  "name": "llmd-mia-worker",
  "version": "0.2.0",
  "private": true,
  "description": "Mia, the Limitless Living MD SMS setter bot. Runs on Cloudflare Workers, driven by Claude.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit",
    "eval": "tsx src/evals/run.ts",
    "db:migrate:local": "wrangler d1 migrations apply llmd_mia --local",
    "db:migrate:remote": "wrangler d1 migrations apply llmd_mia --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250413.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "wrangler": "^3.90.0"
  }
}
